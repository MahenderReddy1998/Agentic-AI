    "\n",
    "# Option B: Use Colab Secrets (recommended)\n",
    "# from google.colab import userdata\n",
    "# os.environ[\"GROQ_API_KEY\"] = userdata.get('GROQ_API_KEY')\n",
    "\n",
    "# Initialize LLaMA 3.1 8B via Groq\n",
    "llm = ChatGroq(\n",
    "    model=\"llama-3.1-8b-instant\",\n",
    "    temperature=0.1,           # Low temperature for deterministic safety decisions\n",
    "    max_tokens=512,\n",
    "    groq_api_key=os.environ[\"GROQ_API_KEY\"]\n",
    ")\n",
    "\n",
    "print(\"✅ Groq LLaMA 3.1 8B Instant initialized.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 4 — Simple Reflex Agent Logic"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# STEP 4: Simple Reflex Agent Core Logic\n",
    "# IF engine_temperature > THRESHOLD → Trigger Automatic Shutdown\n",
    "# ============================================================\n",
    "\n",
    "# --- Safety Thresholds (Kelvin) ---\n",
    "TEMP_THRESHOLD_K     = 3800   # Maximum safe combustion chamber temperature\n",
    "TEMP_WARNING_K       = 3500   # Warning zone temperature\n",
    "TEMP_NOMINAL_MAX_K   = 3200   # Upper nominal operating range\n",
    "TEMP_NOMINAL_MIN_K   = 2800   # Lower nominal operating range\n",
    "\n",
    "# --- Agent State Schema ---\n",
    "class EngineState(TypedDict):\n",
    "    engine_id:        str\n",
    "    temperature_k:    float\n",
    "    pressure_bar:     float\n",
    "    fuel_flow_kgs:    float\n",
    "    vibration_hz:     float\n",
    "    timestamp:        str\n",
    "    reflex_decision:  str      # \"NORMAL\" | \"WARNING\" | \"SHUTDOWN\"\n",
    "    llm_analysis:     str      # LLM reasoning output\n",
    "    final_action:     str      # Final system action taken\n",
    "    alert_level:      str      # \"GREEN\" | \"YELLOW\" | \"RED\"\n",
    "\n",
    "# --- Node 1: Sensor Ingestion & Reflex Rule Engine ---\n",
    "def sensor_reflex_node(state: EngineState) -> EngineState:\n",
    "    \"\"\"\n",
    "    Simple Reflex Agent Rule:\n",
    "    Condition → Action mapping based on engine temperature.\n",
    "    \"\"\"\n",
    "    temp = state[\"temperature_k\"]\n",
    "\n",
    "    if temp > TEMP_THRESHOLD_K:\n",
    "        # CRITICAL: Immediate shutdown trigger\n",
    "        state[\"reflex_decision\"] = \"SHUTDOWN\"\n",
    "        state[\"alert_level\"]     = \"RED\"\n",
    "    elif temp > TEMP_WARNING_K:\n",
    "        # WARNING: Elevated temperature, LLM review required\n",
    "        state[\"reflex_decision\"] = \"WARNING\"\n",
    "        state[\"alert_level\"]     = \"YELLOW\"\n",
    "    else:\n",
    "        # NOMINAL: Temperature within safe operating range\n",
    "        state[\"reflex_decision\"] = \"NORMAL\"\n",
    "        state[\"alert_level\"]     = \"GREEN\"\n",
    "\n",
    "    return state\n",
    "\n",
    "# --- Routing Function: Route based on reflex decision ---\n",
    "def route_decision(state: EngineState) -> Literal[\"llm_analysis\", \"safe_continue\", \"emergency_shutdown\"]:\n",
    "    decision = state[\"reflex_decision\"]\n",
    "    if decision == \"SHUTDOWN\":\n",
    "        return \"emergency_shutdown\"   # Skip LLM — immediate action\n",
    "    elif decision == \"WARNING\":\n",
    "        return \"llm_analysis\"         # LLM reviews borderline case\n",
    "    else:\n",
    "        return \"safe_continue\"        # Normal operation\n",
    "\n",
    "print(\"✅ Reflex agent logic defined.\")\n",
    "print(f\"   Shutdown Threshold : {TEMP_THRESHOLD_K} K\")\n",
    "print(f\"   Warning Threshold  : {TEMP_WARNING_K} K\")\n",
    "print(f\"   Nominal Range      : {TEMP_NOMINAL_MIN_K} – {TEMP_NOMINAL_MAX_K} K\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 5 — LLM Decision Node + LangGraph Assembly"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# STEP 5: LLM Decision Using LLaMA 3.1 8B via Groq\n",
    "# ============================================================\n",
    "\n",
    "SYSTEM_PROMPT = \"\"\"You are SENTINEL, an AI safety officer embedded in the Collins Aerospace\n",
    "Rocket Engine Safety Shutdown System. You analyze sensor telemetry and make\n",
    "precise, authoritative shutdown recommendations.\n",
    "\n",
    "Response format (STRICT JSON only):\n",
    "{\"recommendation\": \"SHUTDOWN\" or \"CONTINUE_MONITORING\" or \"NORMAL\",\n",
    " \"confidence\": 0-100,\n",
    " \"risk_assessment\": \"one sentence\",\n",
    " \"action\": \"exact action to take\",\n",
    " \"reasoning\": \"2-3 sentence technical justification\"}\"\"\"\n",
    "\n",
    "# --- Node 2: LLM Analysis (for WARNING zone) ---\n",
    "def llm_analysis_node(state: EngineState) -> EngineState:\n",
    "    \"\"\"\n",
    "    LLaMA 3.1 8B analyses warning-zone telemetry and decides\n",
    "    whether to escalate to shutdown or continue monitoring.\n",
    "    \"\"\"\n",
    "    user_prompt = f\"\"\"LIVE TELEMETRY — Engine {state['engine_id']}\n",
    "Timestamp      : {state['timestamp']}\n",
    "Temperature    : {state['temperature_k']:.1f} K  (threshold: {TEMP_THRESHOLD_K} K)\n",
    "Pressure       : {state['pressure_bar']:.2f} bar\n",
    "Fuel Flow      : {state['fuel_flow_kgs']:.3f} kg/s\n",
    "Vibration      : {state['vibration_hz']:.1f} Hz\n",
    "Reflex Status  : {state['reflex_decision']}\n",
    "\n",
    "Analyze this WARNING-zone telemetry and provide your recommendation.\"\"\"\n",
    "\n",
    "    try:\n",
    "        response = llm.invoke([\n",
    "            SystemMessage(content=SYSTEM_PROMPT),\n",
    "            HumanMessage(content=user_prompt)\n",
    "        ])\n",
    "        raw = response.content.strip()\n",
    "        # Strip markdown fences if present\n",
    "        raw = raw.replace(\"```json\", \"\").replace(\"```\", \"\").strip()\n",
    "        parsed = json.loads(raw)\n",
    "\n",
    "        state[\"llm_analysis\"] = json.dumps(parsed, indent=2)\n",
    "        # Override reflex if LLM escalates\n",
    "        if parsed.get(\"recommendation\") == \"SHUTDOWN\":\n",
    "            state[\"reflex_decision\"] = \"SHUTDOWN\"\n",
    "            state[\"alert_level\"]     = \"RED\"\n",
    "\n",
    "    except Exception as e:\n",
    "        # Fail-safe: any LLM error in WARNING zone triggers shutdown\n",
    "        state[\"llm_analysis\"]    = json.dumps({\"error\": str(e), \"recommendation\": \"SHUTDOWN\",\n",
    "                                                \"reasoning\": \"LLM unavailable — fail-safe shutdown engaged.\"})\n",
    "        state[\"reflex_decision\"] = \"SHUTDOWN\"\n",
    "        state[\"alert_level\"]     = \"RED\"\n",
    "\n",
    "    return state\n",
    "\n",
    "# --- Node 3: Emergency Shutdown (CRITICAL path) ---\n",
    "def emergency_shutdown_node(state: EngineState) -> EngineState:\n",
    "    state[\"final_action\"]  = (\n",
    "        f\"🔴 EMERGENCY SHUTDOWN EXECUTED | Engine {state['engine_id']} | \"\n",
    "        f\"Temp {state['temperature_k']:.1f} K exceeded {TEMP_THRESHOLD_K} K threshold | \"\n",
    "        f\"{state['timestamp']}\"\n",
    "    )\n",
    "    state[\"llm_analysis\"]  = json.dumps({\n",
    "        \"recommendation\": \"SHUTDOWN\",\n",
    "        \"confidence\": 100,\n",
    "        \"risk_assessment\": \"Temperature exceeds critical threshold — catastrophic failure imminent.\",\n",
    "        \"action\": \"Immediate fuel cutoff and engine isolation.\",\n",
    "        \"reasoning\": (\n",
    "            f\"Engine temperature {state['temperature_k']:.1f} K has breached the absolute \"\n",
    "            f\"safety threshold of {TEMP_THRESHOLD_K} K. Structural integrity of combustion chamber \"\n",
    "            \"is at risk. Automatic shutdown is mandatory per Collins Aerospace Safety Protocol CA-RSP-001.\"\n",
    "        )\n",
    "    }, indent=2)\n",
    "    return state\n",
    "\n",
    "# --- Node 4: Safe Continue ---\n",
    "def safe_continue_node(state: EngineState) -> EngineState:\n",
    "    state[\"final_action\"] = (\n",
    "        f\"🟢 ENGINE NOMINAL | Engine {state['engine_id']} | \"\n",
    "        f\"Temp {state['temperature_k']:.1f} K | All systems GO | {state['timestamp']}\"\n",
    "    )\n",
    "    state[\"llm_analysis\"] = json.dumps({\n",
    "        \"recommendation\": \"NORMAL\",\n",
    "        \"confidence\": 99,\n",
    "        \"risk_assessment\": \"All parameters within nominal operating bounds.\",\n",
    "        \"action\": \"Continue engine burn. No intervention required.\",\n",
    "        \"reasoning\": (\n",
    "            f\"Temperature {state['temperature_k']:.1f} K is within the nominal range \"\n",
    "            f\"of {TEMP_NOMINAL_MIN_K}–{TEMP_NOMINAL_MAX_K} K. \"\n",
    "            \"Propulsion system performing nominally. Launch sequence nominal.\"\n",
    "        )\n",
    "    }, indent=2)\n",
    "    return state\n",
    "\n",
    "# --- Node 5: Post-LLM action dispatcher ---\n",
    "def post_llm_action_node(state: EngineState) -> EngineState:\n",
    "    if state[\"reflex_decision\"] == \"SHUTDOWN\":\n",
    "        return emergency_shutdown_node(state)\n",
    "    else:\n",
    "        state[\"final_action\"] = (\n",
    "            f\"🟡 MONITORING ELEVATED | Engine {state['engine_id']} | \"\n",
    "            f\"Temp {state['temperature_k']:.1f} K | LLM: Continue Monitoring | {state['timestamp']}\"\n",
    "        )\n",
    "    return state\n",
    "\n",
    "# ============================================================\n",
    "# Build the LangGraph State Machine\n",
    "# ============================================================\n",
    "graph = StateGraph(EngineState)\n",
    "\n",
    "# Add nodes\n",
    "graph.add_node(\"sensor_reflex\",      sensor_reflex_node)\n",
    "graph.add_node(\"llm_analysis\",       llm_analysis_node)\n",
    "graph.add_node(\"emergency_shutdown\", emergency_shutdown_node)\n",
    "graph.add_node(\"safe_continue\",      safe_continue_node)\n",
    "graph.add_node(\"post_llm_action\",    post_llm_action_node)\n",
    "\n",
    "# Entry point\n",
    "graph.set_entry_point(\"sensor_reflex\")\n",
    "\n",
    "# Conditional routing after reflex node\n",
    "graph.add_conditional_edges(\n",
    "    \"sensor_reflex\",\n",
    "    route_decision,\n",
    "    {\n",
    "        \"emergency_shutdown\": \"emergency_shutdown\",\n",
    "        \"llm_analysis\":       \"llm_analysis\",\n",
    "        \"safe_continue\":      \"safe_continue\",\n",
    "    }\n",
    ")\n",
    "\n",
    "# After LLM, route to post_llm_action\n",
    "graph.add_edge(\"llm_analysis\",       \"post_llm_action\")\n",
    "graph.add_edge(\"post_llm_action\",    END)\n",
    "graph.add_edge(\"emergency_shutdown\", END)\n",
    "graph.add_edge(\"safe_continue\",      END)\n",
    "\n",
    "# Compile the agent\n",
    "agent = graph.compile()\n",
    "\n",
    "print(\"✅ LangGraph Simple Reflex Agent compiled.\")\n",
    "print(\"   Nodes  : sensor_reflex → [emergency_shutdown | llm_analysis → post_llm_action | safe_continue]\")"
   ]
  },
