    "# ============================================================\n",
    "# STEP 6: Gradio — Professional Collins Aerospace UI\n",
    "# Light theme, animated ticker, real-time telemetry dashboard\n",
    "# ============================================================\n",
    "\n",
    "# ---------- Helper: Run the agent ----------\n",
    "def run_agent(engine_id, temperature_k, pressure_bar, fuel_flow_kgs, vibration_hz):\n",
    "    \"\"\"Run the LangGraph agent and return formatted results.\"\"\"\n",
    "    timestamp = datetime.datetime.utcnow().strftime(\"%Y-%m-%dT%H:%M:%S UTC\")\n",
    "\n",
    "    initial_state: EngineState = {\n",
    "        \"engine_id\":       engine_id,\n",
    "        \"temperature_k\":   float(temperature_k),\n",
    "        \"pressure_bar\":    float(pressure_bar),\n",
    "        \"fuel_flow_kgs\":   float(fuel_flow_kgs),\n",
    "        \"vibration_hz\":    float(vibration_hz),\n",
    "        \"timestamp\":       timestamp,\n",
    "        \"reflex_decision\": \"\",\n",
    "        \"llm_analysis\":    \"\",\n",
    "        \"final_action\":    \"\",\n",
    "        \"alert_level\":     \"GREEN\",\n",
    "    }\n",
    "\n",
    "    result = agent.invoke(initial_state)\n",
    "\n",
    "    # Parse LLM JSON\n",
    "    try:\n",
    "        llm_data = json.loads(result[\"llm_analysis\"])\n",
    "    except:\n",
    "        llm_data = {\"recommendation\": \"N/A\", \"confidence\": 0,\n",
    "                    \"risk_assessment\": \"N/A\", \"action\": \"N/A\", \"reasoning\": \"N/A\"}\n",
    "\n",
    "    alert     = result[\"alert_level\"]\n",
    "    decision  = result[\"reflex_decision\"]\n",
    "    action    = result[\"final_action\"]\n",
    "    conf      = llm_data.get(\"confidence\", 0)\n",
    "    risk      = llm_data.get(\"risk_assessment\", \"\")\n",
    "    reasoning = llm_data.get(\"reasoning\", \"\")\n",
    "    llm_rec   = llm_data.get(\"recommendation\", \"\")\n",
    "    llm_act   = llm_data.get(\"action\", \"\")\n",
    "\n",
    "    # Status badge\n",
    "    badge_map = {\n",
    "        \"GREEN\":  (\"🟢 ALL SYSTEMS NOMINAL\",   \"#d4edda\", \"#155724\"),\n",
    "        \"YELLOW\": (\"🟡 WARNING — MONITORING\",  \"#fff3cd\", \"#856404\"),\n",
    "        \"RED\":    (\"🔴 EMERGENCY SHUTDOWN\",     \"#f8d7da\", \"#721c24\"),\n",
    "    }\n",
    "    badge_text, badge_bg, badge_fg = badge_map.get(alert, badge_map[\"GREEN\"])\n",
    "\n",
    "    status_html = f\"\"\"\n",
    "    <div style=\"background:{badge_bg};color:{badge_fg};padding:18px 24px;\n",
    "                border-radius:10px;font-size:1.3em;font-weight:700;\n",
    "                border:2px solid {badge_fg};letter-spacing:1px;text-align:center;\">\n",
    "      {badge_text}\n",
    "    </div>\n",
    "    \"\"\"\n",
    "\n",
    "    telemetry_html = f\"\"\"\n",
    "    <div style=\"font-family:'Courier New',monospace;background:#f8f9fa;\n",
    "                border:1px solid #dee2e6;border-radius:8px;padding:16px;\">\n",
    "      <table style=\"width:100%;border-collapse:collapse;\">\n",
    "        <tr style=\"border-bottom:1px solid #dee2e6;\">\n",
    "          <td style=\"padding:6px 12px;color:#6c757d;font-size:0.85em;\">ENGINE ID</td>\n",
    "          <td style=\"padding:6px 12px;font-weight:700;color:#212529;\">{engine_id}</td>\n",
    "          <td style=\"padding:6px 12px;color:#6c757d;font-size:0.85em;\">TIMESTAMP</td>\n",
    "          <td style=\"padding:6px 12px;font-weight:700;color:#212529;\">{timestamp}</td>\n",
    "        </tr>\n",
    "        <tr style=\"border-bottom:1px solid #dee2e6;\">\n",
    "          <td style=\"padding:6px 12px;color:#6c757d;font-size:0.85em;\">TEMPERATURE</td>\n",
    "          <td style=\"padding:6px 12px;font-weight:700;color:{'#dc3545' if temperature_k>TEMP_THRESHOLD_K else '#fd7e14' if temperature_k>TEMP_WARNING_K else '#198754'};\">{temperature_k:.1f} K</td>\n",
    "          <td style=\"padding:6px 12px;color:#6c757d;font-size:0.85em;\">THRESHOLD</td>\n",
    "          <td style=\"padding:6px 12px;font-weight:700;color:#212529;\">{TEMP_THRESHOLD_K} K</td>\n",
    "        </tr>\n",
    "        <tr style=\"border-bottom:1px solid #dee2e6;\">\n",
    "          <td style=\"padding:6px 12px;color:#6c757d;font-size:0.85em;\">PRESSURE</td>\n",
    "          <td style=\"padding:6px 12px;font-weight:700;color:#212529;\">{pressure_bar:.2f} bar</td>\n",
    "          <td style=\"padding:6px 12px;color:#6c757d;font-size:0.85em;\">FUEL FLOW</td>\n",
    "          <td style=\"padding:6px 12px;font-weight:700;color:#212529;\">{fuel_flow_kgs:.3f} kg/s</td>\n",
    "        </tr>\n",
    "        <tr>\n",
    "          <td style=\"padding:6px 12px;color:#6c757d;font-size:0.85em;\">VIBRATION</td>\n",
    "          <td style=\"padding:6px 12px;font-weight:700;color:#212529;\">{vibration_hz:.1f} Hz</td>\n",
    "          <td style=\"padding:6px 12px;color:#6c757d;font-size:0.85em;\">REFLEX</td>\n",
    "          <td style=\"padding:6px 12px;font-weight:700;color:{'#dc3545' if decision=='SHUTDOWN' else '#fd7e14' if decision=='WARNING' else '#198754'};\">{decision}</td>\n",
    "        </tr>\n",
    "      </table>\n",
    "    </div>\n",
    "    \"\"\"\n",
    "\n",
    "    llm_html = f\"\"\"\n",
    "    <div style=\"background:#ffffff;border:1px solid #dee2e6;border-radius:8px;padding:16px;\">\n",
    "      <div style=\"display:flex;justify-content:space-between;margin-bottom:12px;\">\n",
    "        <span style=\"font-weight:700;color:#0d1b2a;font-size:0.95em;\">🤖 SENTINEL AI — LLaMA 3.1 8B Analysis</span>\n",
    "        <span style=\"background:#e9ecef;padding:3px 10px;border-radius:20px;\n",
    "                    font-size:0.8em;font-weight:600;color:#495057;\">Confidence: {conf}%</span>\n",
    "      </div>\n",
    "      <div style=\"margin-bottom:8px;\">\n",
    "        <span style=\"color:#6c757d;font-size:0.8em;\">RECOMMENDATION</span><br/>\n",
    "        <span style=\"font-weight:700;font-size:1.0em;color:{'#dc3545' if 'SHUTDOWN' in llm_rec else '#198754'};\">{llm_rec}</span>\n",
    "      </div>\n",
    "      <div style=\"margin-bottom:8px;\">\n",
    "        <span style=\"color:#6c757d;font-size:0.8em;\">RISK ASSESSMENT</span><br/>\n",
    "        <span style=\"color:#212529;font-size:0.9em;\">{risk}</span>\n",
    "      </div>\n",
    "      <div style=\"margin-bottom:8px;\">\n",
    "        <span style=\"color:#6c757d;font-size:0.8em;\">PRESCRIBED ACTION</span><br/>\n",
    "        <span style=\"color:#0d6efd;font-weight:600;font-size:0.9em;\">{llm_act}</span>\n",
    "      </div>\n",
    "      <div style=\"background:#f8f9fa;padding:10px;border-radius:6px;\">\n",
    "        <span style=\"color:#6c757d;font-size:0.8em;\">TECHNICAL REASONING</span><br/>\n",
    "        <span style=\"color:#343a40;font-size:0.85em;line-height:1.5;\">{reasoning}</span>\n",
    "      </div>\n",
    "    </div>\n",
    "    \"\"\"\n",
    "\n",
    "    action_html = f\"\"\"\n",
    "    <div style=\"background:#0d1b2a;color:#f8f9fa;padding:14px 18px;\n",
    "                border-radius:8px;font-family:'Courier New',monospace;\n",
    "                font-size:0.85em;border-left:4px solid {'#dc3545' if alert=='RED' else '#ffc107' if alert=='YELLOW' else '#198754'};\">\n",
    "      <span style=\"color:#6c757d;font-size:0.8em;\">SYSTEM LOG</span><br/>\n",
    "      {action}\n",
    "    </div>\n",
    "    \"\"\"\n",
    "\n",
    "    return status_html, telemetry_html, llm_html, action_html\n",
    "\n",
    "\n",
    "# ---------- Gradio App ----------\n",
    "TICKER_CSS = \"\"\"\n",
    "<style>\n",
    "  @import url('https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;900&family=Barlow+Condensed:wght@700;900&display=swap');\n",
    "\n",
    "  /* Animated ticker */\n",
    "  .ca-ticker-wrap {\n",
    "    width:100%; overflow:hidden;\n",
    "    background:linear-gradient(90deg,#0d1b2a 0%,#1a3a5c 50%,#0d1b2a 100%);\n",
    "    border-bottom:2px solid #e8a020; padding:0; margin-bottom:0;\n",
    "  }\n",
    "  .ca-ticker-inner {\n",
    "    display:flex; align-items:center;\n",
    "    animation:ticker 28s linear infinite;\n",
    "    white-space:nowrap; padding:10px 0;\n",
    "  }\n",
    "  .ca-ticker-inner:hover { animation-play-state:paused; }\n",
    "  @keyframes ticker {\n",
    "    0%  { transform:translateX(100vw); }\n",
    "    100%{ transform:translateX(-100%); }\n",
    "  }\n",
    "  .ca-ticker-item {\n",
    "    font-family:'Barlow Condensed',sans-serif;\n",
    "    font-size:0.9em; font-weight:700; letter-spacing:2px;\n",
    "    color:#f0f4f8; margin-right:60px; text-transform:uppercase;\n",
    "  }\n",
    "  .ca-ticker-dot {\n",
    "    display:inline-block; width:8px; height:8px;\n",
    "    border-radius:50%; background:#e8a020;\n",
    "    margin-right:60px; vertical-align:middle;\n",
    "  }\n",
    "</style>\n",
    "<div class=\"ca-ticker-wrap\">\n",
    "  <div class=\"ca-ticker-inner\">\n",
    "    <span class=\"ca-ticker-item\">🚀 Rocket Engine Safety Shutdown System</span>\n",
    "    <span class=\"ca-ticker-dot\"></span>\n",
    "    <span class=\"ca-ticker-item\">Collins Aerospace — Advanced Propulsion Safety Division</span>\n",
    "    <span class=\"ca-ticker-dot\"></span>\n",
    "    <span class=\"ca-ticker-item\">SENTINEL AI v2.1 — LLaMA 3.1 8B Instant via Groq</span>\n",
    "    <span class=\"ca-ticker-dot\"></span>\n",
    "    <span class=\"ca-ticker-item\">Protocol: CA-RSP-001 | Threshold: 3800 K | Real-Time Monitoring Active</span>\n",
    "    <span class=\"ca-ticker-dot\"></span>\n",
    "    <span class=\"ca-ticker-item\">Simple Reflex Agent • LangGraph • Catastrophic Failure Prevention</span>\n",
    "    <span class=\"ca-ticker-dot\"></span>\n",
    "    <span class=\"ca-ticker-item\">🚀 Rocket Engine Safety Shutdown System</span>\n",
    "    <span class=\"ca-ticker-dot\"></span>\n",
    "  </div>\n",
    "</div>\n",
    "\"\"\"\n",
    "\n",
    "HEADER_HTML = \"\"\"\n",
    "<div style=\"background:#ffffff;border-bottom:3px solid #0d1b2a;padding:20px 28px;\n",
    "            display:flex;align-items:center;justify-content:space-between;\">\n",
    "  <div style=\"display:flex;align-items:center;gap:16px;\">\n",
    "    <div style=\"background:#0d1b2a;color:#e8a020;font-family:'Barlow Condensed',sans-serif;\n",
    "                font-weight:900;font-size:1.6em;letter-spacing:3px;\n",
    "                padding:10px 16px;border-radius:6px;\">CA</div>\n",
    "    <div>\n",
    "      <div style=\"font-family:'Barlow',sans-serif;font-weight:900;font-size:1.25em;\n",
    "                  color:#0d1b2a;letter-spacing:1px;line-height:1.1;\">COLLINS AEROSPACE</div>\n",
    "      <div style=\"font-family:'Barlow',sans-serif;font-size:0.75em;color:#6c757d;\n",
    "                  letter-spacing:3px;text-transform:uppercase;\">Propulsion Safety Systems</div>\n",
    "    </div>\n",
    "  </div>\n",
    "  <div style=\"text-align:right;\">\n",
    "    <div style=\"font-family:'Barlow',sans-serif;font-weight:700;font-size:0.8em;\n",
    "                color:#0d1b2a;letter-spacing:2px;\">SENTINEL AI</div>\n",
    "    <div style=\"font-family:'Barlow',sans-serif;font-size:0.7em;color:#6c757d;\">Engine Safety Shutdown • v2.1</div>\n",
    "  </div>\n",
    "</div>\n",
    "\"\"\"\n",
    "\n",
    "# ---- Build Gradio Interface ----\n",
    "with gr.Blocks(\n",
    "    theme=gr.themes.Default(\n",
    "        primary_hue=\"blue\",\n",
    "        neutral_hue=\"slate\",\n",
    "        font=[gr.themes.GoogleFont(\"Barlow\"), \"sans-serif\"],\n",
    "    ),\n",
    "    css=\"\"\"\n",
    "        body { background:#f0f4f8 !important; }\n",
    "        .gr-button-primary { background:#0d1b2a !important; border:none !important;\n",
    "                             font-weight:700 !important; letter-spacing:1px !important; }\n",
    "        .gr-button-primary:hover { background:#1a3a5c !important; }\n",
    "        footer { display:none !important; }\n",
    "    \"\"\",\n",
    "    title=\"Collins Aerospace — Rocket Engine Safety Shutdown\"\n",
    ") as demo:\n",
    "\n",
    "    # Animated ticker + header\n",
    "    gr.HTML(TICKER_CSS)\n",
    "    gr.HTML(HEADER_HTML)\n",
    "\n",
    "    with gr.Row():\n",
    "        gr.HTML(\"\"\"\n",
    "        <div style=\"padding:8px 28px;background:#e9ecef;font-family:'Barlow',sans-serif;\n",
    "                    font-size:0.78em;color:#495057;letter-spacing:1px;\n",
    "                    border-bottom:1px solid #dee2e6;\">\n",
    "          LIVE TELEMETRY ANALYSIS &nbsp;|&nbsp; SIMPLE REFLEX AGENT &nbsp;|&nbsp;\n",
    "          LANGGRAPH STATE MACHINE &nbsp;|&nbsp; LLaMA 3.1 8B INSTANT (GROQ)\n",
    "        </div>\"\"\")\n",
    "\n",
    "    with gr.Row(equal_height=False):\n",
    "        # ---- LEFT PANEL: Inputs ----\n",
    "        with gr.Column(scale=1):\n",
    "            gr.HTML(\"\"\"<div style=\"font-family:'Barlow',sans-serif;font-weight:700;\n",
    "                        font-size:0.85em;color:#0d1b2a;letter-spacing:2px;\n",
    "                        padding:10px 0 6px;border-bottom:2px solid #e8a020;\n",
    "                        margin-bottom:14px;\">⚙️ ENGINE PARAMETERS</div>\"\"\")\n",
    "\n",
    "            engine_id   = gr.Dropdown(\n",
    "                choices=[\"ENG-01 (RS-25)\", \"ENG-02 (RS-25)\", \"ENG-03 (RL-10)\",\n",
    "                         \"ENG-04 (BE-4)\", \"ENG-05 (Merlin)\"],\n",
    "                value=\"ENG-01 (RS-25)\",\n",
    "                label=\"Engine Identification\"\n",
    "            )\n",
    "            temperature = gr.Slider(\n",
    "                minimum=1000, maximum=4500, value=3100, step=10,\n",
    "                label=\"Combustion Chamber Temperature (K)\",\n",
    "                info=\"Shutdown threshold: 3800 K | Warning: 3500 K\"\n",
    "            )\n",
    "            pressure    = gr.Slider(\n",
    "                minimum=50, maximum=300, value=206.4, step=0.1,\n",
    "                label=\"Chamber Pressure (bar)\"\n",
    "            )\n",
    "            fuel_flow   = gr.Slider(\n",
    "                minimum=0.1, maximum=1.5, value=0.487, step=0.001,\n",
    "                label=\"Fuel Flow Rate (kg/s)\"\n",
    "            )\n",
    "            vibration   = gr.Slider(\n",
    "                minimum=0, maximum=500, value=42.0, step=0.5,\n",
    "                label=\"Vibration Frequency (Hz)\"\n",
    "            )\n",
    "\n",
    "            gr.HTML(\"\"\"<div style=\"font-family:'Barlow',sans-serif;font-weight:700;\n",
    "                        font-size:0.85em;color:#0d1b2a;letter-spacing:2px;\n",
    "                        padding:12px 0 6px;border-bottom:2px solid #e8a020;\n",
    "                        margin-bottom:10px;\">🎯 QUICK SCENARIOS</div>\"\"\")\n",
    "\n",
    "            with gr.Row():\n",
    "                btn_nominal  = gr.Button(\"🟢 Nominal\",  variant=\"secondary\", size=\"sm\")\n",
    "                btn_warning  = gr.Button(\"🟡 Warning\",  variant=\"secondary\", size=\"sm\")\n",
    "                btn_critical = gr.Button(\"🔴 Critical\", variant=\"secondary\", size=\"sm\")\n",
    "\n",
    "            run_btn = gr.Button(\n",
    "                \"▶  RUN SAFETY ANALYSIS\",\n",
    "                variant=\"primary\",\n",
    "                size=\"lg\"\n",
    "            )\n",
    "\n",
    "            gr.HTML(\"\"\"<div style=\"font-family:'Barlow',sans-serif;font-size:0.72em;\n",
    "                        color:#6c757d;padding:10px 0;line-height:1.6;\">\n",
    "              <strong>Agent Flow:</strong><br/>\n",
    "              Sensor Input → Reflex Rule Check<br/>\n",
    "              &nbsp;&nbsp;↳ T > 3800K → Emergency Shutdown<br/>\n",
    "              &nbsp;&nbsp;↳ T > 3500K → LLM Analysis → Decision<br/>\n",
    "              &nbsp;&nbsp;↳ T ≤ 3500K → Safe Continue\n",
    "            </div>\"\"\")\n",
    "\n",
    "        # ---- RIGHT PANEL: Outputs ----\n",
    "        with gr.Column(scale=2):\n",
    "            gr.HTML(\"\"\"<div style=\"font-family:'Barlow',sans-serif;font-weight:700;\n",
    "                        font-size:0.85em;color:#0d1b2a;letter-spacing:2px;\n",
    "                        padding:10px 0 6px;border-bottom:2px solid #e8a020;\n",
    "                        margin-bottom:14px;\">📡 SYSTEM STATUS</div>\"\"\")\n",
    "\n",
    "            status_out    = gr.HTML(label=\"Alert Status\")\n",
    "            telemetry_out = gr.HTML(label=\"Telemetry Data\")\n",
    "            llm_out       = gr.HTML(label=\"AI Analysis\")\n",
    "            action_out    = gr.HTML(label=\"System Log\")\n",
    "\n",
    "    # ---- Footer ----\n",
    "    gr.HTML(\"\"\"\n",
    "    <div style=\"background:#0d1b2a;color:#6c757d;padding:14px 28px;\n",
    "                font-family:'Barlow',sans-serif;font-size:0.72em;\n",
    "                display:flex;justify-content:space-between;align-items:center;\n",
    "                border-top:2px solid #e8a020;margin-top:8px;\">\n",
    "      <span>© 2025 Collins Aerospace. All Rights Reserved. | Proprietary Software</span>\n",
    "      <span>SENTINEL AI v2.1 | Protocol CA-RSP-001 | LangGraph + LLaMA 3.1 8B via Groq</span>\n",
    "    </div>\n",
    "    \"\"\")\n",
    "\n",
    "    # ---- Quick Scenario Presets ----\n",
    "    def set_nominal():  return gr.update(value=3100), gr.update(value=206.4), gr.update(value=0.487), gr.update(value=42.0)\n",
    "    def set_warning():  return gr.update(value=3620), gr.update(value=228.0), gr.update(value=0.512), gr.update(value=89.0)\n",
    "    def set_critical(): return gr.update(value=4150), gr.update(value=265.0), gr.update(value=0.601), gr.update(value=187.0)\n",
    "\n",
    "    btn_nominal.click(set_nominal,  outputs=[temperature, pressure, fuel_flow, vibration])\n",
    "    btn_warning.click(set_warning,  outputs=[temperature, pressure, fuel_flow, vibration])\n",
    "    btn_critical.click(set_critical, outputs=[temperature, pressure, fuel_flow, vibration])\n",
    "\n",
    "    # ---- Main analysis trigger ----\n",
    "    run_btn.click(\n",
    "        fn=run_agent,\n",
    "        inputs=[engine_id, temperature, pressure, fuel_flow, vibration],\n",
    "        outputs=[status_out, telemetry_out, llm_out, action_out]\n",
    "    )\n",
    "\n",
    "demo.launch(share=True, debug=False)\n",
    "print(\"\\n✅ Gradio interface launched. Click the link above to open the dashboard.\")"
   ]
  }
 ]
}"